    "@hono/node-server": "^1.13.7",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "isomorphic-dompurify": "^2.18.0",
    "markdown-it": "^14.1.0",
    "next": "14.2.18",
    "postgres": "^3.4.5",
    "react": "18.3.1",
